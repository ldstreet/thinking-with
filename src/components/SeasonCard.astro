---
import type { Season } from '../data/podcast';
import { u } from '../lib/url';
interface Props { season: Season; count?: number; }
const { season: s, count } = Astro.props;
const inProduction = s.status === 'in-production';
---

<a class="scard" href={u(`/seasons/${s.slug}`)} style={`--accent:${s.accent}; --accent-ink:${s.accentInk}`}>
  <div class="scard-cover">
    {s.cover ? (
      <img src={u(s.cover)} alt={`${s.alias} — season ${s.number} cover art`} loading="lazy" width="600" height="600" />
    ) : (
      <div class="scard-placeholder">
        <span class="ph-thinker">{s.thinker}</span>
        <span class="ph-alias">{s.alias}</span>
      </div>
    )}
    {inProduction && <span class="scard-flag">In production</span>}
  </div>
  <div class="scard-body">
    <span class="scard-no">Season {s.number}{count ? ` · ${count} episodes` : ''}</span>
    <h3 class="scard-title">{s.alias}</h3>
    <p class="scard-work">Thinking With… <em>{s.work}</em></p>
    {s.theme && <span class="scard-theme">Theme · {s.theme}</span>}
  </div>
</a>

<style>
  .scard {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--paper-card);
    border: 1px solid var(--line-soft);
    box-shadow: var(--shadow);
    transition: transform 0.18s ease, box-shadow 0.18s ease;
  }
  .scard:hover { transform: translateY(-4px); box-shadow: var(--shadow-lift); }
  .scard-cover { position: relative; aspect-ratio: 1 / 1; background: var(--accent); overflow: hidden; }
  .scard-cover img { width: 100%; height: 100%; object-fit: cover; }
  .scard:hover .scard-cover img { transform: scale(1.02); transition: transform 0.4s ease; }
  .scard-placeholder {
    position: absolute; inset: 0;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    gap: 0.5rem; text-align: center; padding: 1.5rem;
    background:
      radial-gradient(120% 80% at 50% 0%, color-mix(in srgb, var(--accent) 70%, #000 8%), var(--accent));
    color: var(--accent-ink);
  }
  .ph-thinker { font-size: 0.74rem; letter-spacing: 0.18em; text-transform: uppercase; opacity: 0.85; }
  .ph-alias { font-family: var(--font-display); font-size: 2rem; line-height: 1.05; }
  .scard-flag {
    position: absolute; top: 0.8rem; left: 0.8rem;
    font-family: var(--font-body); font-size: 0.7rem; font-weight: 700;
    letter-spacing: 0.08em; text-transform: uppercase;
    background: var(--paper); color: var(--ink);
    padding: 0.3rem 0.6rem; border-radius: 999px;
  }
  .scard-body { padding: 1.2rem 1.3rem 1.4rem; display: grid; gap: 0.25rem; }
  .scard-no {
    font-family: var(--font-body); font-size: 0.74rem; font-weight: 600;
    letter-spacing: 0.1em; text-transform: uppercase; color: var(--accent);
  }
  .scard-title { font-size: 1.5rem; margin: 0.1rem 0 0; }
  .scard-work { margin: 0; color: var(--ink-soft); font-size: 0.95rem; }
  .scard-work em { font-style: italic; }
  .scard-theme {
    margin-top: 0.35rem;
    font-family: var(--font-body); font-size: 0.7rem; font-weight: 700;
    letter-spacing: 0.1em; text-transform: uppercase; color: var(--teal);
  }
</style>
