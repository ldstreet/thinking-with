---
import { listen } from '../data/podcast';
interface Props { size?: 'sm' | 'md'; }
const { size = 'md' } = Astro.props;
---

<div class={`subscribe subscribe--${size}`}>
  <a class="btn btn--ghost" href={listen.apple} target="_blank" rel="noopener">
    <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="currentColor"><path d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20Zm0 4.4a2.2 2.2 0 1 1 0 4.4 2.2 2.2 0 0 1 0-4.4Zm-3.6 9.1c0-1.6 2.4-2.5 3.6-2.5s3.6.9 3.6 2.5v.6c0 .4-.3.7-.7.7H9.1a.7.7 0 0 1-.7-.7v-.6Z"/></svg>
    Apple Podcasts
  </a>
  <a class="btn btn--ghost" href={listen.spotify} target="_blank" rel="noopener">
    <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="currentColor"><path d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20Zm4.6 14.4a.8.8 0 0 1-1.1.3c-3-1.8-6.7-2.2-11.1-1.2a.8.8 0 1 1-.3-1.5c4.8-1.1 8.9-.6 12.2 1.4.4.2.5.7.3 1Zm1.2-2.8a1 1 0 0 1-1.3.3c-3.4-2.1-8.6-2.7-12.6-1.5a1 1 0 0 1-.6-1.9c4.6-1.4 10.3-.7 14.2 1.7.5.3.6 1 .3 1.4Zm.1-2.9C14 8.2 7.7 8 4.2 9a1.2 1.2 0 1 1-.7-2.3C7.6 5.5 14.5 5.7 18.9 8.3a1.2 1.2 0 0 1-1.2 2.1l.2-.6Z"/></svg>
    Spotify
  </a>
  <a class="btn btn--ghost" href={listen.rss} target="_blank" rel="noopener">
    <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" fill="currentColor"><path d="M4 11a9 9 0 0 1 9 9h-3a6 6 0 0 0-6-6v-3Zm0-5a14 14 0 0 1 14 14h-3A11 11 0 0 0 4 9V6Zm2.2 9.6a2 2 0 1 1 0 4 2 2 0 0 1 0-4Z"/></svg>
    RSS
  </a>
</div>

<style>
  .subscribe { display: flex; flex-wrap: wrap; gap: 0.6rem; }
  .subscribe--sm .btn { padding: 0.5rem 0.85rem; font-size: 0.85rem; }
</style>
