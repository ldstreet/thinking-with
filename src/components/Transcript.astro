---
// Interactive, timestamped transcript reader.
// Fetches a WebVTT file client-side, MERGES the many short whisper cues into
// readable paragraphs (one timestamp each), and keeps them in sync with the given
// <audio> element (seek on click, highlight + auto-scroll the active block).
// Compact by default: the body is height-capped and scrolls within itself, with an
// "Expand" toggle to read the whole thing inline.
interface Props {
  vttUrl: string;
  /** id of the <audio> element this transcript drives. */
  audioId: string;
  /** Optional download links shown above the transcript. */
  downloads?: { label: string; href: string }[];
  note?: string;
}
const { vttUrl, audioId, downloads = [], note } = Astro.props;
---

<section class="transcript" data-vtt={vttUrl} data-audio={audioId}>
  <div class="t-head">
    <h2 class="t-title">Transcript</h2>
    <div class="t-tools">
      <label class="t-follow">
        <input type="checkbox" class="t-follow-input" checked />
        Follow playback
      </label>
      {downloads.length > 0 && (
        <span class="t-downloads">
          {downloads.map((d) => (
            <a href={d.href} download>{d.label}</a>
          ))}
        </span>
      )}
    </div>
  </div>
  {note && <p class="t-note">{note}</p>}
  <input class="t-search" type="search" placeholder="Search this transcript…" aria-label="Search transcript" />
  <div class="t-wrap">
    <ol class="t-cues" aria-live="off">
      <li class="t-loading">Loading transcript…</li>
    </ol>
    <div class="t-fade" aria-hidden="true"></div>
  </div>
  <button type="button" class="t-expand" aria-expanded="false" hidden>Expand full transcript</button>
</section>

<script>
  function fmtTime(s: number): string {
    const h = Math.floor(s / 3600);
    const m = Math.floor((s % 3600) / 60);
    const sec = Math.floor(s % 60);
    const mm = String(m).padStart(2, '0');
    const ss = String(sec).padStart(2, '0');
    return h ? `${h}:${mm}:${ss}` : `${m}:${ss}`;
  }

  function parseTimestamp(t: string): number {
    const parts = t.trim().split(':');
    let s = 0;
    for (const p of parts) s = s * 60 + parseFloat(p.replace(',', '.'));
    return s;
  }

  interface Cue { start: number; end: number; text: string; speaker?: string; }

  // Extract a WebVTT voice tag (<v Name>text</v>) if present, returning the
  // speaker name and the plain text. Falls back to plain text when absent.
  function parseVoice(raw: string): { speaker?: string; text: string } {
    const m = raw.match(/^<v\s+([^>]+)>([\s\S]*?)(?:<\/v>)?\s*$/);
    if (m) return { speaker: m[1].trim(), text: m[2].trim() };
    return { text: raw.replace(/<\/?v[^>]*>/g, '').trim() };
  }

  // Stable colour per speaker: the three hosts get fixed hues site-wide;
  // unknown guests cycle the remaining slots in order of appearance.
  const FIXED: Record<string, number> = { nathaniel: 0, nate: 1, john: 2, guest: 3 };
  const seen: string[] = [];
  function speakerClass(name?: string): string {
    if (!name) return '';
    const k = name.toLowerCase();
    if (k in FIXED) return `sp-${FIXED[k]}`;
    let i = seen.indexOf(name);
    if (i < 0) i = seen.push(name) - 1;
    return `sp-${4 + (i % 2)}`;
  }

  function parseVtt(raw: string): Cue[] {
    const cues: Cue[] = [];
    const blocks = raw.replace(/\r/g, '').split('\n\n');
    for (const block of blocks) {
      const lines = block.split('\n').filter(Boolean);
      const timing = lines.find((l) => l.includes('-->'));
      if (!timing) continue;
      const [a, b] = timing.split('-->');
      const start = parseTimestamp(a);
      const end = parseTimestamp(b.trim().split(' ')[0]);
      const rawText = lines.slice(lines.indexOf(timing) + 1).join(' ').trim();
      if (!rawText) continue;
      const { speaker, text } = parseVoice(rawText);
      if (!text) continue;
      cues.push({ start, end, text, speaker });
    }
    return cues;
  }

  // Merge short cues into paragraph-sized blocks for compact, readable scanning.
  function groupCues(cues: Cue[]): Cue[] {
    const MAX_CHARS = 420;
    const MAX_SPAN = 60; // seconds
    const out: Cue[] = [];
    let cur: Cue | null = null;
    for (const c of cues) {
      if (!cur) { cur = { ...c }; continue; }
      const span = c.end - cur.start;
      const wouldLen = cur.text.length + 1 + c.text.length;
      const endsSentence = /[.!?]["”’)]?\s*$/.test(cur.text);
      const speakerChanged = c.speaker !== cur.speaker;
      if (speakerChanged || wouldLen > MAX_CHARS || span > MAX_SPAN || (endsSentence && cur.text.length > 240)) {
        out.push(cur);
        cur = { ...c };
      } else {
        cur.text += ' ' + c.text;
        cur.end = c.end;
      }
    }
    if (cur) out.push(cur);
    return out;
  }

  function initTranscript(root: HTMLElement) {
    const vttUrl = root.dataset.vtt!;
    const audio = document.getElementById(root.dataset.audio!) as HTMLAudioElement | null;
    const scroll = root.querySelector('.t-wrap') as HTMLElement;
    const list = root.querySelector('.t-cues') as HTMLOListElement;
    const follow = root.querySelector('.t-follow-input') as HTMLInputElement;
    const search = root.querySelector('.t-search') as HTMLInputElement;
    const expand = root.querySelector('.t-expand') as HTMLButtonElement;

    expand.addEventListener('click', () => {
      const open = root.classList.toggle('is-expanded');
      expand.setAttribute('aria-expanded', String(open));
      expand.textContent = open ? 'Collapse transcript' : 'Expand full transcript';
    });

    fetch(vttUrl)
      .then((r) => (r.ok ? r.text() : Promise.reject(r.status)))
      .then((raw) => {
        const cues = groupCues(parseVtt(raw));
        list.innerHTML = '';
        const items: HTMLLIElement[] = cues.map((c) => {
          const li = document.createElement('li');
          li.className = 't-cue';
          li.dataset.start = String(c.start);
          li.dataset.end = String(c.end);
          const time = document.createElement('button');
          time.className = 't-time';
          time.type = 'button';
          time.textContent = fmtTime(c.start);
          time.addEventListener('click', () => {
            if (!audio) return;
            audio.currentTime = c.start;
            audio.play();
          });
          const body = document.createElement('div');
          body.className = 't-body';
          if (c.speaker) {
            const who = document.createElement('span');
            who.className = `t-speaker ${speakerClass(c.speaker)}`;
            who.textContent = c.speaker;
            body.appendChild(who);
          }
          const span = document.createElement('span');
          span.className = 't-text';
          span.textContent = c.text;
          body.appendChild(span);
          li.append(time, body);
          list.appendChild(li);
          return li;
        });

        // Only offer expand/collapse if the transcript actually overflows the cap.
        if (scroll.scrollHeight > scroll.clientHeight + 8) expand.hidden = false;

        // Highlight + autoscroll the active block during playback.
        let active = -1;
        const sync = () => {
          if (!audio) return;
          const t = audio.currentTime;
          let idx = -1;
          for (let i = 0; i < cues.length; i++) {
            if (t >= cues[i].start && t < cues[i].end) { idx = i; break; }
            if (t >= cues[i].start) idx = i;
          }
          if (idx === active) return;
          if (active >= 0) items[active]?.classList.remove('is-active');
          active = idx;
          if (idx >= 0 && follow.checked) {
            const el = items[idx];
            el.classList.add('is-active');
            // scroll within the capped panel (or the page when expanded)
            const target = root.classList.contains('is-expanded') ? undefined : scroll;
            if (target) {
              const top = el.offsetTop - target.clientHeight / 2 + el.clientHeight / 2;
              target.scrollTo({ top, behavior: 'smooth' });
            } else {
              el.scrollIntoView({ block: 'center', behavior: 'smooth' });
            }
          } else if (idx >= 0) {
            items[idx].classList.add('is-active');
          }
        };
        audio?.addEventListener('timeupdate', sync);

        // Search filter.
        search.addEventListener('input', () => {
          const q = search.value.trim().toLowerCase();
          for (const li of items) {
            const txt = (li.querySelector('.t-text') as HTMLElement).textContent!.toLowerCase();
            (li as HTMLElement).style.display = !q || txt.includes(q) ? '' : 'none';
          }
        });
      })
      .catch(() => {
        list.innerHTML = '<li class="t-loading">Transcript could not be loaded.</li>';
      });
  }

  document.querySelectorAll<HTMLElement>('.transcript').forEach(initTranscript);
</script>

<!-- Global: the cue rows are created client-side and never receive Astro's
     scoping attribute, so scoped rules wouldn't reach them. All selectors here
     are uniquely t-/transcript-prefixed, so global is safe. -->
<style is:global>
  .transcript { margin-top: 2.5rem; }
  .t-head {
    display: flex; flex-wrap: wrap; align-items: baseline; justify-content: space-between;
    gap: 0.8rem; border-bottom: 1px solid var(--line-soft); padding-bottom: 0.6rem;
  }
  .t-title { margin: 0; font-size: 1.5rem; }
  .t-tools { display: flex; align-items: center; gap: 1rem; font-size: 0.85rem; }
  .t-follow { display: flex; align-items: center; gap: 0.35rem; color: var(--ink-soft); cursor: pointer; }
  .t-downloads { display: flex; gap: 0.7rem; }
  .t-downloads a { color: var(--accent); text-decoration: none; font-weight: 600; }
  .t-downloads a:hover { text-decoration: underline; }
  .t-note { color: var(--ink-faint); font-size: 0.82rem; font-style: italic; margin: 0.6rem 0 0; }
  .t-search {
    width: 100%; margin: 1rem 0 0.4rem; padding: 0.55rem 0.8rem;
    border: 1px solid var(--line-soft); border-radius: var(--radius); background: var(--paper-2);
    font: inherit; font-size: 0.92rem;
  }

  /* compact, height-capped scroll panel */
  .t-wrap { position: relative; max-height: 32rem; overflow-y: auto; scroll-behavior: smooth; }
  .transcript.is-expanded .t-wrap { max-height: none; overflow: visible; }
  .t-fade {
    position: sticky; bottom: 0; left: 0; right: 0; height: 3.5rem; margin-top: -3.5rem;
    background: linear-gradient(transparent, var(--paper)); pointer-events: none;
  }
  .transcript.is-expanded .t-fade { display: none; }

  .t-cues { list-style: none; margin: 0.6rem 0 0; padding: 0; max-width: 46rem; }
  .t-loading { color: var(--ink-faint); padding: 0.6rem 0; }
  .t-cue {
    display: grid; grid-template-columns: 3.6rem 1fr; gap: 0.7rem;
    padding: 0.4rem 0.5rem; border-radius: var(--radius); scroll-margin: 40vh;
  }
  .t-cue.is-active { background: color-mix(in srgb, var(--accent) 14%, transparent); }
  .t-time {
    background: none; border: none; padding: 0; cursor: pointer;
    font-family: var(--font-body); font-size: 0.78rem; font-variant-numeric: tabular-nums;
    color: var(--accent); text-align: left; line-height: 1.7;
  }
  .t-time:hover { text-decoration: underline; }
  .t-body { min-width: 0; }
  .t-text { color: var(--ink); line-height: 1.7; }
  .t-cue.is-active .t-text { color: var(--ink); font-weight: 500; }

  /* Speaker attribution label (rendered when the VTT has <v Name> voice tags). */
  .t-speaker {
    display: block; font-size: 0.72rem; font-weight: 700;
    letter-spacing: 0.06em; text-transform: uppercase;
    line-height: 1.7; margin-bottom: 0.05rem; color: var(--sp, var(--ink-soft));
  }
  .t-speaker.sp-0 { --sp: #2f7d6b; }
  .t-speaker.sp-1 { --sp: #3a5f9e; }
  .t-speaker.sp-2 { --sp: #8d4a86; }
  .t-speaker.sp-3 { --sp: #8a6d2f; }
  .t-speaker.sp-4 { --sp: #5a6470; }
  .t-speaker.sp-5 { --sp: #b0563a; }
  :root[data-theme='dark'] .t-speaker.sp-0 { --sp: #6cbfab; }
  :root[data-theme='dark'] .t-speaker.sp-1 { --sp: #8fb0e6; }
  :root[data-theme='dark'] .t-speaker.sp-2 { --sp: #d199c8; }
  :root[data-theme='dark'] .t-speaker.sp-3 { --sp: #cBae6a; }
  :root[data-theme='dark'] .t-speaker.sp-4 { --sp: #a8b4c2; }
  :root[data-theme='dark'] .t-speaker.sp-5 { --sp: #e58c6a; }

  .t-expand {
    margin-top: 0.8rem;
    font-family: var(--font-body); font-size: 0.9rem; font-weight: 600;
    color: var(--accent); background: none; border: 1px solid var(--line);
    padding: 0.5rem 1rem; border-radius: 999px; cursor: pointer;
    transition: border-color 0.15s ease, background 0.15s ease;
  }
  .t-expand:hover { border-color: var(--accent); background: color-mix(in srgb, var(--accent) 8%, transparent); }

  @media (prefers-reduced-motion: reduce) {
    .t-wrap { scroll-behavior: auto; }
  }
</style>
