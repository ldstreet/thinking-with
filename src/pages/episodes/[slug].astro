---
import Base from '../../layouts/Base.astro';
import SubscribeLinks from '../../components/SubscribeLinks.astro';
import Transcript from '../../components/Transcript.astro';
import { allEpisodes } from '../../lib/episodes';
import { transcriptFor } from '../../lib/transcripts';
import { notesFor, asParagraphs } from '../../lib/episodeNotes';
import { guestsFor } from '../../lib/guests';
import { u } from '../../lib/url';

export function getStaticPaths() {
  return allEpisodes.map((ep) => ({ params: { slug: ep.slug }, props: { ep } }));
}

const { ep } = Astro.props;
const tr = transcriptFor(ep.guid);
const note = notesFor(ep.guid);
const summaryParas = note ? asParagraphs(note.summary) : [];
const overview = note?.overview ?? [];
const chapters = note?.chapters ?? [];
const refs = note?.references ?? [];
const epGuests = guestsFor(ep.guid);

function fmtDuration(d?: string) {
  if (!d) return '';
  const p = d.split(':').map(Number);
  if (p.length === 3) return `${p[0]} hr ${p[1]} min`;
  if (p.length === 2) return `${p[0]} min`;
  return d;
}

const downloads = tr
  ? [
      { label: 'VTT', href: u(tr.vtt) },
      ...(tr.srt ? [{ label: 'SRT', href: u(tr.srt) }] : []),
      ...(tr.txt ? [{ label: 'Text', href: u(tr.txt) }] : []),
    ]
  : [];

const trNote = tr
  ? `Auto-generated from the audio with Whisper ${tr.model ?? ''}`.trim() +
    '. May contain errors — corrections welcome.'
  : '';
---

<Base
  title={ep.title}
  description={ep.description ?? `${ep.seasonAlias} — ${ep.title}`}
>
  <section class="ep-hero" style={`--accent:${ep.accent}; --accent-ink:${ep.accentInk}`}>
    <div class="wrap">
      <a href={u(ep.seasonSlug ? `/seasons/${ep.seasonSlug}` : '/podcasts')} class="back">← {ep.seasonAlias}</a>
      <p class="eyebrow on-accent">
        {ep.seasonAlias}{ep.episode ? ` · Episode ${ep.episode}` : ''}
      </p>
      <h1 class="ep-title">{ep.title}</h1>
      <div class="ep-meta">
        <span>{ep.dateLabel}</span>
        {ep.duration && <span aria-hidden="true">·</span>}
        {ep.duration && <span>{fmtDuration(ep.duration)}</span>}
      </div>
      {ep.description && <p class="ep-desc">{ep.description}</p>}
      {epGuests.length > 0 && (
        <div class="ep-guests">
          <span class="ep-guests-label">Featuring</span>
          <ul>
            {epGuests.map((g) => (
              <li>
                {g.url ? <a href={g.url} target="_blank" rel="noopener">{g.name}</a> : <span>{g.name}</span>}
                {g.role && <span class="ep-guest-role">{g.role}</span>}
              </li>
            ))}
          </ul>
        </div>
      )}
      <audio id="ep-audio" class="ep-audio" controls preload="none" src={ep.audio}></audio>
    </div>
  </section>

  {note && (
    <section class="section notes-section" style={`--accent:${ep.accent}; --accent-ink:${ep.accentInk}`}>
      <div class="wrap notes-wrap">
        {(summaryParas.length > 0 || overview.length > 0) && (
          <div class="note-block">
            <h2 class="note-h">Overview</h2>
            {summaryParas.length > 0
              ? summaryParas.map((p) => <p>{p}</p>)
              : overview.map((p) => <p>{p}</p>)}
            {summaryParas.length > 0 && overview.length > 0 && (
              <p class="reading muted">Reading: {overview.join(' · ')}</p>
            )}
          </div>
        )}

        {chapters.length > 0 && (
          <div class="note-block">
            <h2 class="note-h">In this episode</h2>
            <ol class="chapters">
              {chapters.map((c) => (
                <li class="chapter">
                  <button class="ch-time" type="button" data-seek={c.start} title="Jump to this point">{c.time}</button>
                  <span class="ch-label">{c.label}</span>
                </li>
              ))}
            </ol>
          </div>
        )}

        {note.pages && (
          <div class="note-block">
            <h2 class="note-h">Pages discussed</h2>
            <p>{note.pages}</p>
          </div>
        )}

        {refs.length > 0 && (
          <div class="note-block">
            <h2 class="note-h">Texts &amp; thinkers</h2>
            <ul class="refs">
              {refs.map((r) => (
                <li>
                  {r.url ? (
                    <a href={r.url} target="_blank" rel="noopener">{r.label}</a>
                  ) : (
                    <span>{r.label}</span>
                  )}
                  {r.note && <span class="ref-note muted"> — {r.note}</span>}
                </li>
              ))}
            </ul>
          </div>
        )}

        {note.drafted && (
          <p class="drafted-flag muted">The overview and links here are auto-drafted from the episode. Corrections welcome.</p>
        )}
      </div>
    </section>
  )}

  <section class="section">
    <div class="wrap">
      {tr ? (
        <Transcript vttUrl={u(tr.vtt)} audioId="ep-audio" downloads={downloads} note={trNote} />
      ) : (
        <div class="t-pending card">
          <h2>Transcript coming soon</h2>
          <p class="muted">
            We're generating timestamped transcripts for every episode. This one will appear here
            shortly.
          </p>
        </div>
      )}
      <div class="ep-sub">
        <p class="eyebrow">Listen & subscribe</p>
        <SubscribeLinks size="sm" />
      </div>
    </div>
  </section>
</Base>

<style>
  .ep-hero { background: var(--paper-2); border-bottom: 1px solid var(--line-soft); }
  .ep-hero .wrap { padding-block: clamp(2rem, 5vw, 3.2rem); max-width: 52rem; }
  .back { font-family: var(--font-body); font-size: 0.9rem; color: var(--ink-soft); text-decoration: none; }
  .back:hover { color: var(--ink); }
  .eyebrow.on-accent { color: var(--accent); margin-top: 1rem; }
  .ep-title { font-size: clamp(2rem, 6vw, 3.2rem); margin: 0.2rem 0 0.5rem; line-height: 1.1; }
  .ep-meta { display: flex; gap: 0.5rem; font-size: 0.9rem; color: var(--ink-faint); margin-bottom: 1rem; }
  .ep-desc { font-size: 1.05rem; color: var(--ink-soft); max-width: 44rem; }
  .ep-guests { margin-top: 1.2rem; }
  .ep-guests-label {
    font-family: var(--font-body); font-size: 0.72rem; font-weight: 700;
    letter-spacing: 0.12em; text-transform: uppercase; color: var(--accent);
  }
  .ep-guests ul { list-style: none; margin: 0.3rem 0 0; padding: 0; display: grid; gap: 0.3rem; }
  .ep-guests li { display: flex; flex-wrap: wrap; align-items: baseline; gap: 0.5rem; }
  .ep-guests a { color: var(--ink); font-weight: 600; text-decoration: underline; text-underline-offset: 2px; }
  .ep-guests a:hover { color: var(--accent); }
  .ep-guest-role { font-size: 0.85rem; color: var(--ink-faint); }
  .ep-audio { width: 100%; height: 44px; margin-top: 1.3rem; }
  .ep-audio::-webkit-media-controls-panel { background: var(--paper); }
  .t-pending { padding: 2rem; text-align: center; display: grid; gap: 0.5rem; justify-items: center; }
  .t-pending h2 { margin: 0; }
  .ep-sub { margin-top: 3rem; padding-top: 2rem; border-top: 1px solid var(--line-soft); }

  /* show notes */
  .notes-section { padding-bottom: 0; }
  .notes-wrap { max-width: 52rem; display: grid; gap: 2rem; }
  .note-block { display: grid; gap: 0.5rem; }
  .note-h {
    font-size: 0.78rem; font-family: var(--font-body); font-weight: 700;
    letter-spacing: 0.14em; text-transform: uppercase; color: var(--accent);
    margin: 0 0 0.2rem; padding-bottom: 0.5rem; border-bottom: 1px solid var(--line-soft);
  }
  .note-block > p { font-size: 1.05rem; color: var(--ink-soft); margin: 0; }
  .reading { font-size: 0.92rem !important; font-style: italic; }

  /* timestamped chapters */
  .chapters { list-style: none; margin: 0; padding: 0; display: grid; gap: 0.7rem; }
  .chapter { display: grid; grid-template-columns: 5.6rem 1fr; gap: 0.8rem; align-items: baseline; }
  .ch-time {
    background: none; border: none; padding: 0; cursor: pointer; text-align: left;
    font-family: var(--font-body); font-size: 0.82rem; font-weight: 600;
    font-variant-numeric: tabular-nums; color: var(--accent); line-height: 1.6;
  }
  .ch-time:hover { text-decoration: underline; }
  .ch-label { color: var(--ink-soft); line-height: 1.6; }

  .refs { margin: 0; padding-left: 1.2rem; display: grid; gap: 0.5rem; }
  .refs a { color: var(--ink); font-weight: 600; text-underline-offset: 2px; }
  .refs a:hover { color: var(--accent); }
  .ref-note { font-weight: 400; }
  .drafted-flag { font-size: 0.82rem !important; font-style: italic; margin: 0 !important; }
</style>

<script is:inline>
  // Make chapter timestamps seek the episode audio.
  (() => {
    const audio = document.getElementById('ep-audio');
    if (!audio) return;
    document.querySelectorAll('.ch-time[data-seek]').forEach((btn) => {
      btn.addEventListener('click', () => {
        audio.currentTime = Number(btn.getAttribute('data-seek')) || 0;
        audio.play();
        audio.scrollIntoView({ block: 'center', behavior: 'smooth' });
      });
    });
  })();
</script>
