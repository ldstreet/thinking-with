---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { u } from '../../lib/url';

const posts = (await getCollection('writing'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Base title="Writing" description="Essays, provocations, and reading notes from Thinking With… — including the Rhetorical Theory of Language series and the Critique reading group.">
  <section class="section">
    <div class="wrap">
      <p class="eyebrow">Writing</p>
      <h1 class="page-title">Some thoughts want to be read.</h1>
      <p class="lede prose-wrap">
        Essays, provocations, and reading notes between episodes — including work toward a
        rhetorical theory of language and materials for our Critique reading group.
      </p>

      <ul class="posts">
        {posts.map((p) => (
          <li class="post">
            <a href={u(`/writing/${p.slug}`)} class="post-link">
              <div class="post-meta">
                <time datetime={p.data.date.toISOString()}>{fmt(p.data.date)}</time>
                {p.data.series && <span class="series-tag">{p.data.series}</span>}
                {p.data.draft && <span class="pill draft">Draft</span>}
              </div>
              <h2 class="post-title">{p.data.title}</h2>
              <p class="post-desc">{p.data.description}</p>
              <span class="post-by muted">{p.data.author}</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>
</Base>

<style>
  .page-title { font-size: clamp(2.2rem, 6vw, 3.6rem); }
  .lede { margin-bottom: 2.8rem; }
  .posts { list-style: none; padding: 0; margin: 0; max-width: 48rem; display: grid; gap: 0; }
  .post { border-top: 1px solid var(--line); }
  .post:last-child { border-bottom: 1px solid var(--line); }
  .post-link {
    display: block; text-decoration: none; color: inherit;
    padding: 1.8rem 0.4rem; transition: background 0.15s ease, padding 0.15s ease;
  }
  .post-link:hover { background: var(--paper-2); padding-inline: 1rem; }
  .post-meta { display: flex; align-items: center; gap: 0.8rem; font-size: 0.82rem; color: var(--ink-faint); margin-bottom: 0.4rem; }
  .series-tag { color: var(--accent); font-weight: 600; }
  .draft { font-size: 0.66rem; padding: 0.15rem 0.5rem; }
  .post-title { font-size: 1.7rem; margin: 0 0 0.3rem; }
  .post-desc { margin: 0 0 0.5rem; color: var(--ink-soft); }
  .post-by { font-size: 0.85rem; }
</style>
