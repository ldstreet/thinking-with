---
import Base from '../layouts/Base.astro';
import SeasonCard from '../components/SeasonCard.astro';
import SubscribeLinks from '../components/SubscribeLinks.astro';
import { seasons, series } from '../data/podcast';
import episodes from '../data/episodes.json';
import { u } from '../lib/url';

const counts: Record<string, number> = Object.fromEntries(
  Object.entries(episodes.bySeason).map(([k, v]) => [k, (v as unknown[]).length])
);
---

<Base title="Podcasts" description="Six seasons of Thinking With… — Hegel, Deleuze, Heidegger, Derrida, and Nietzsche, read slowly and closely.">
  <section class="section">
    <div class="wrap">
      <p class="eyebrow">The Seasons</p>
      <h1 class="page-title">Six seasons of slow reading.</h1>
      <p class="lede prose-wrap">
        Each season takes a single major work and stays with it — following the text where it
        leads, less to explain it than to think alongside it. Start anywhere.
      </p>
      <div class="sub"><SubscribeLinks size="sm" /></div>

      <div class="grid">
        {seasons.map((s) => (
          <SeasonCard season={s} count={counts[String(s.number)]} />
        ))}
      </div>
    </div>
  </section>

  <section class="section series-section">
    <div class="wrap">
      <p class="divider-label">Series &amp; Segments</p>
      <div class="series-grid">
        {series.map((sr) => (
          <a class="series-card" href={u(`/series/${sr.slug}`)} style={`--accent:${sr.accent}`}>
            <h3>{sr.title}</h3>
            <p class="series-tag">{sr.tagline}</p>
            <p class="series-blurb">{sr.blurb}</p>
            <span class="series-more">Explore →</span>
          </a>
        ))}
      </div>
    </div>
  </section>
</Base>

<style>
  .page-title { font-size: clamp(2.2rem, 6vw, 3.6rem); }
  .sub { margin: 1.4rem 0 2.6rem; }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(255px, 1fr));
    gap: 1.6rem;
  }
  .series-section { padding-top: 0; }
  .series-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.4rem; margin-top: 1.8rem; }
  .series-card {
    display: block;
    text-decoration: none;
    color: inherit;
    padding: 1.6rem 1.7rem;
    border-radius: var(--radius-lg);
    background: var(--paper-card);
    border: 1px solid var(--line-soft);
    border-top: 4px solid var(--accent);
    box-shadow: var(--shadow);
    transition: transform 0.18s ease, box-shadow 0.18s ease;
  }
  .series-card:hover { transform: translateY(-3px); box-shadow: var(--shadow-lift); }
  .series-card h3 { font-size: 1.7rem; margin: 0; }
  .series-tag {
    color: var(--accent); font-weight: 600; font-size: 0.9rem;
    margin: 0.2rem 0 0.8rem; font-style: italic;
  }
  .series-blurb { color: var(--ink-soft); margin: 0 0 1rem; font-size: 0.98rem; }
  .series-more { font-family: var(--font-body); font-weight: 600; font-size: 0.9rem; color: var(--ink); }
  @media (max-width: 680px) { .series-grid { grid-template-columns: 1fr; } }
</style>
